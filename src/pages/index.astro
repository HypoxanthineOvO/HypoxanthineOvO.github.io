---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { formatDate, sortByDateDesc } from '../lib/content';
import { blogSubcategoryLabels } from '../lib/site';

const blogPosts = sortByDateDesc(await getCollection('blog', ({ data }) => !data.draft));
const teachingEntries = await getCollection('teaching');
const courseEntries = await getCollection('courses');
const publicationEntries = await getCollection('publications');
---

<Base title="Landing" description="Landing page placeholder for the Astro rebuild.">
  <section class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-8 rounded-[2rem] border border-paper-3 bg-paper-2 p-8 dark:border-ink-3 dark:bg-ink-2 lg:grid-cols-[1.25fr_0.75fr]">
      <div class="space-y-6">
        <p class="text-sm uppercase tracking-[0.2em] text-accent">Landing</p>
        <h1 class="max-w-3xl text-5xl font-semibold tracking-tight text-ink dark:text-paper">
          Essays, academic notes, teaching records, and publication context.
        </h1>
        <p class="max-w-2xl text-base leading-8 text-ink-3 dark:text-paper-3">
          Placeholder landing page for the Astro rebuild. Prompt B can refine hero copy, featured logic, and final
          visual hierarchy.
        </p>
      </div>
      <div class="rounded-[2rem] border border-dashed border-accent/30 bg-accent-soft/60 p-6 text-sm leading-7 text-ink-3 dark:border-paper/20 dark:bg-ink dark:text-paper-3">
        <p class="font-semibold text-ink dark:text-paper">Scaffold status</p>
        <p class="mt-3">Blog, academia, tags, archive, RSS, theme toggling, and content collections are in place.</p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-6">
    <div class="mb-6 flex items-center justify-between">
      <h2 class="text-2xl font-semibold tracking-tight">Latest Writing</h2>
      <a class="text-sm text-accent hover:text-accent-hover" href="/blog/">View all</a>
    </div>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {blogPosts.slice(0, 3).map((post) => (
        <PostCard
          href={`/blog/${post.data.subcategory}/${post.id}/`}
          title={post.data.title}
          summary={post.data.summary}
          eyebrow={blogSubcategoryLabels[post.data.subcategory]}
          meta={formatDate(post.data.date)}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-6">
    <div class="grid gap-6 lg:grid-cols-3">
      <PostCard
        href="/academia/teaching/"
        title="Teaching"
        summary={`Collection placeholder with ${teachingEntries.length} example item(s).`}
        eyebrow="Academia"
      />
      <PostCard
        href="/academia/courses/"
        title="Courses"
        summary={`Collection placeholder with ${courseEntries.length} example item(s).`}
        eyebrow="Academia"
      />
      <PostCard
        href="/academia/publications/"
        title="Publications"
        summary={`Collection placeholder with ${publicationEntries.length} example item(s).`}
        eyebrow="Academia"
      />
    </div>
  </section>
</Base>
