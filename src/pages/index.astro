---
import Hero from '../components/Hero.astro';
import NoteCard from '../components/NoteCard.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PublicationCard from '../components/PublicationCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getNotes, getPosts, getProjects, getPublications } from '../lib/content';

const recentPosts = (await getPosts()).slice(0, 3);
const recentNotes = (await getNotes()).slice(0, 3);
const featuredPublications = (await getPublications()).filter((entry) => entry.data.featured).slice(0, 3);
const featuredProjects = (await getProjects()).filter((entry) => entry.data.featured).slice(0, 3);
---

<BaseLayout>
  <section class="section-band section-band--subtle">
    <div class="shell">
      <Hero />
    </div>
  </section>

  <section class="section-band section-band--alt">
    <div class="shell">
      <SectionHeader kicker="About" title="Short Context" href="/about" actionLabel="Read more" />
      <div class="content-shell space-y-4 text-muted md:mx-0 md:max-w-[760px] md:px-0">
        <p>
          The site is being rebuilt around four content types: long-form posts, compact notes, publications, and
          project records.
        </p>
        <p>
          Prompt B focuses on the structural shell only, so several texts here are intentionally marked as placeholders
          until the full Hexo-to-Astro migration pass lands.
        </p>
      </div>
    </div>
  </section>

  <section class="section-band section-band--default">
    <div class="shell">
      <SectionHeader kicker="Featured" title="Publications" href="/publications" actionLabel="View all" />
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {featuredPublications.map((publication) => <PublicationCard publication={publication} />)}
      </div>
    </div>
  </section>

  <section class="section-band section-band--alt">
    <div class="shell">
      <SectionHeader kicker="Recent Posts" title="Posts" href="/posts" actionLabel="View all" />
      <div class="content-shell rounded-3xl border border-border bg-bg px-6 py-2 md:mx-0 md:max-w-none md:px-8">
        {recentPosts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>

  <section class="section-band section-band--default">
    <div class="shell">
      <SectionHeader kicker="Recent Notes" title="Notes" href="/notes" actionLabel="View all" />
      <div class="content-shell rounded-3xl border border-border bg-bg px-6 py-2 md:mx-0 md:max-w-none md:px-8">
        {recentNotes.map((note) => <NoteCard note={note} />)}
      </div>
    </div>
  </section>

  <section class="section-band section-band--alt">
    <div class="shell">
      <SectionHeader kicker="Projects" title="Featured Projects" href="/projects" actionLabel="View all" />
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>
