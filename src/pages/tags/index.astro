---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, formatTagLabel, getNotes, getPosts, toTagParam } from '../../lib/content';
import { knownTags } from '../../lib/site';

const tags = collectTags([...(await getPosts()), ...(await getNotes())]);
const counts = new Map(tags.map((item) => [item.tag, item.count]));
const allTags = [...new Set([...knownTags, ...tags.map((item) => item.tag)])]
  .map((tag) => ({ tag, count: counts.get(tag) ?? 0 }))
  .sort((a, b) => b.count - a.count || a.tag.localeCompare(b.tag, 'en'));
const maxCount = Math.max(...allTags.map((item) => item.count), 1);
---

<BaseLayout title="全站标签云" description="全站标签云（含文章与笔记）。">
  <section class="shell pb-20">
    <div class="section-heading">
      <div>
        <p class="section-kicker">标签</p>
        <h1>全站标签云（含文章与笔记）</h1>
      </div>
    </div>

    <div class="content-shell md:mx-0 md:max-w-[820px] md:px-0">
      <p class="mb-8 text-muted">这里同时统计文章与笔记中的标签。即使当前某个标签暂时没有命中内容，也会保留固定路由，便于后续内容扩展。</p>
      <div class="flex flex-wrap gap-4">
        {allTags.map(({ tag, count }) => (
          <a
            href={`/tags/${toTagParam(tag)}`}
            class="font-sans transition-colors duration-150 hover:text-accent"
            style={`font-size: ${1 + (count / maxCount) * 1.1}rem; color: var(--muted);`}
          >
            {formatTagLabel(tag)} <span class="text-xs">({count})</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
