---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, formatTagLabel, getPosts, toTagParam } from '../../lib/content';

const tags = collectTags(await getPosts());
const maxCount = Math.max(...tags.map((item) => item.count), 1);
---

<BaseLayout title="Tags" description="Tag cloud for post tags only.">
  <section class="shell pb-20">
    <div class="section-heading">
      <div>
        <p class="section-kicker">Navigation</p>
        <h1>Tags</h1>
      </div>
    </div>

    <div class="content-shell md:mx-0 md:max-w-[820px] md:px-0">
      <p class="mb-8 text-muted">The tag cloud below only indexes Posts. Notes keep their filtering inline on the notes page.</p>
      <div class="flex flex-wrap gap-4">
        {tags.map(({ tag, count }) => (
          <a
            href={`/tags/${toTagParam(tag)}`}
            class="font-sans transition-colors duration-150 hover:text-accent"
            style={`font-size: ${1 + (count / maxCount) * 1.1}rem; color: var(--muted);`}
          >
            {formatTagLabel(tag)} <span class="text-xs">({count})</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
