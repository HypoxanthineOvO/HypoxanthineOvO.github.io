---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, formatTagLabel, getNotes, getPosts, toTagParam } from '../../lib/content';

const tags = collectTags([...(await getPosts()), ...(await getNotes())]);
const maxCount = Math.max(...tags.map((item) => item.count), 1);
---

<BaseLayout title="标签" description="按开集标签聚合的文章与笔记索引。">
  <section class="shell pb-20">
    <div class="section-heading">
      <div>
        <p class="section-kicker">标签</p>
        <h1>标签</h1>
      </div>
    </div>

    <div class="content-shell md:mx-0 md:max-w-[820px] md:px-0">
      <p class="mb-8 text-muted">全站标签云（含文章与笔记），默认不显示锁库的 humanities 条目。</p>

      {tags.length > 0 ? (
        <div class="flex flex-wrap gap-4">
          {tags.map(({ tag, count }) => (
            <a
              href={`/tags/${toTagParam(tag)}`}
              class="font-sans transition-colors duration-150 hover:text-accent"
              style={`font-size: ${1 + (count / maxCount) * 1.1}rem; color: var(--muted);`}
            >
              {formatTagLabel(tag)} <span class="text-xs">({count})</span>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-muted">暂无标签。</p>
      )}
    </div>
  </section>
</BaseLayout>
