---
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatTagLabel, getPosts, toTagParam } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getPosts();
  const tags = [...new Set(posts.flatMap((entry) => entry.data.tags))];

  return tags.map((tag) => ({
    params: { tag: toTagParam(tag) },
    props: {
      tag,
      posts: posts.filter((entry) => entry.data.tags.includes(tag)),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`Tag: ${formatTagLabel(tag)}`} description={`Posts tagged ${formatTagLabel(tag)}.`}>
  <section class="shell pb-20">
    <div class="section-heading">
      <div>
        <p class="section-kicker">Filtered Posts</p>
        <h1>{formatTagLabel(tag)}</h1>
      </div>
    </div>

    <div class="content-shell rounded-3xl border border-border px-6 py-2 md:mx-0 md:max-w-[780px] md:px-8">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
