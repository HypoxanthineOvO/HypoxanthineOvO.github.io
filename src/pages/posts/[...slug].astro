---
import { render } from 'astro:content';

import PostLayout from '../../layouts/PostLayout.astro';
import { getAdjacentArchiveEntries, getSeriesEntries, getPosts } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getPosts();

  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const seriesEntries = await getSeriesEntries(entry.data.series, { includeArchived: entry.data.archived });
const { newer, older } = getAdjacentArchiveEntries(seriesEntries, `/posts/${entry.id}`);
const { Content, headings } = await render(entry);
---

<PostLayout entry={entry} Content={Content} headings={headings} newer={newer} older={older} />
