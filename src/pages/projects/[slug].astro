---
import { render } from 'astro:content';

import TagArchiveCard from '../../components/TagArchiveCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prose from '../../components/Prose.astro';
import { getProjectLogEntries, getProjects } from '../../lib/content';

export async function getStaticPaths() {
  const projects = await getProjects();

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const logEntries = await getProjectLogEntries(project.id);
const recentLogs = logEntries.slice(0, 5);

const statusLabelMap = {
  active: '进行中',
  wip: '开发中',
  archived: '已归档',
  internal: '内部使用',
} as const;

const badgeClassMap = {
  active: 'status-badge--active',
  wip: 'status-badge--wip',
  archived: 'status-badge--archived',
  internal: 'status-badge--internal',
} as const;

const githubMarkPath =
  'M12 .297a12 12 0 0 0-3.794 23.385c.6.113.82-.258.82-.577v-2.234c-3.338.726-4.042-1.416-4.042-1.416a3.18 3.18 0 0 0-1.335-1.755c-1.09-.745.083-.729.083-.729a2.52 2.52 0 0 1 1.84 1.237 2.555 2.555 0 0 0 3.49.997 2.554 2.554 0 0 1 .762-1.6C7.16 17.31 4.36 16.27 4.36 11.67a4.573 4.573 0 0 1 1.218-3.172 4.25 4.25 0 0 1 .116-3.127s.996-.318 3.26 1.214a11.274 11.274 0 0 1 5.932 0c2.264-1.532 3.26-1.214 3.26-1.214a4.25 4.25 0 0 1 .116 3.127 4.573 4.573 0 0 1 1.218 3.172c0 4.61-2.804 5.636-5.475 5.932a2.868 2.868 0 0 1 .814 2.224v3.293c0 .322.216.694.825.576A12.003 12.003 0 0 0 12 .297Z';
---

<BaseLayout title={project.data.name} description={project.data.description}>
  <article class="shell pb-20">
    <div class="content-shell md:mx-0 md:max-w-[780px] md:px-0">
      <p class="section-kicker">项目</p>
      <div class="mb-5 flex flex-wrap items-center gap-3">
        {project.data.emoji && <span class="text-[1.5rem]" aria-hidden="true">{project.data.emoji}</span>}
        <h1>{project.data.name}</h1>
        <span class:list={['status-badge', badgeClassMap[project.data.status]]}>
          {statusLabelMap[project.data.status]}
        </span>
      </div>

      <p class="mb-6 text-[1.05rem] text-muted">{project.data.description}</p>

      <div class="mb-10 flex flex-wrap gap-3 font-sans text-sm">
        {project.data.githubUrl && (
          <a class="link-btn" href={project.data.githubUrl} target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
              <path d={githubMarkPath}></path>
            </svg>
            GitHub
          </a>
        )}
        <a class="inline-link" href="/projects">返回项目列表</a>
      </div>

      <Prose>
        <Content />
      </Prose>

      {recentLogs.length > 0 && (
        <section class="mt-12">
          <div class="mb-5 flex items-center justify-between gap-4">
            <h2 class="text-[1.5rem]">最近日志</h2>
            {logEntries.length > 5 && (
              <a class="section-link" href={`/projects/${project.id}/log`}>
                查看全部 {logEntries.length} 篇 <span class="section-link-arrow">→</span>
              </a>
            )}
          </div>

          <div class="rounded-3xl border border-border px-6 py-2 md:px-8">
            {recentLogs.map((entry) => (
              <TagArchiveCard
                href={entry.href}
                title={entry.title}
                description={entry.description}
                date={entry.date}
                tags={entry.tags}
                type={entry.type}
                series={entry.series}
              />
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</BaseLayout>
