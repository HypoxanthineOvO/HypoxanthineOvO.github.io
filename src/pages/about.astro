---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../lib/site';
---

<BaseLayout title="About" description="Placeholder about page for the Astro rebuild.">
  <section class="shell pb-20">
    <div class="content-shell md:mx-0 md:px-0">
      <p class="section-kicker">Profile</p>
      <h1 class="mb-6">About</h1>
      <div class="space-y-4 text-muted">
        <p>
          Hypoxanthine He is currently represented here with placeholder copy for the Prompt B skeleton. The long-form
          biography will be rewritten after the content migration step.
        </p>
        <p>
          Current placeholder frame: graduate student at ShanghaiTech University, broadly interested in Cryo-GPU
          systems, research tooling, and computational workflows that connect theory with usable infrastructure.
        </p>
        <p>
          Contact links for the rebuilt site stay intentionally minimal:
          <a class="inline-link" href={siteConfig.github} target="_blank" rel="noreferrer">GitHub</a>
          and
          <a class="inline-link" href={`mailto:${siteConfig.email}`}>Email</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
