<Base title="About" description="About page placeholder for the Astro rebuild.">
  <section class="mx-auto max-w-4xl px-6 py-10">
    <p class="text-sm uppercase tracking-[0.2em] text-accent">About</p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight">About this site</h1>
    <div class="prose prose-slate mt-6 max-w-none dark:prose-invert">
      <p>This placeholder page will eventually hold the final biography, interests, and contact details.</p>
      <p>Prompt B can replace this copy after content migration decisions are settled.</p>
    </div>
  </section>
</Base>
