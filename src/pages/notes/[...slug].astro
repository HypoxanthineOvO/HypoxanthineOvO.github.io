---
import { render } from 'astro:content';

import NoteLayout from '../../layouts/NoteLayout.astro';
import { getAdjacentEntries, getNotes } from '../../lib/content';

export async function getStaticPaths() {
  const notes = await getNotes();

  return notes.map((entry) => {
    const { newer, older } = getAdjacentEntries(notes, entry.id);

    return {
      params: { slug: entry.id },
      props: { entry, newer, older },
    };
  });
}

const { entry, newer, older } = Astro.props;
const { Content, headings } = await render(entry);
---

<NoteLayout entry={entry} Content={Content} headings={headings} newer={newer} older={older} />
