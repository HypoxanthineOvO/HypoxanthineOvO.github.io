---
import { render } from 'astro:content';

import NoteLayout from '../../layouts/NoteLayout.astro';
import { getAdjacentArchiveEntries, getNotes, getSeriesEntries } from '../../lib/content';

export async function getStaticPaths() {
  const notes = await getNotes();

  return notes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const seriesEntries = await getSeriesEntries(entry.data.series, { includeArchived: entry.data.archived });
const { newer, older } = getAdjacentArchiveEntries(seriesEntries, `/notes/${entry.id}`);
const { Content, headings } = await render(entry);
---

<NoteLayout entry={entry} Content={Content} headings={headings} newer={newer} older={older} />
