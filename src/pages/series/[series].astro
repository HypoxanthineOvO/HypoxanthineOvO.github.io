---
import Pagination from '../../components/Pagination.astro';
import RewriteNotice from '../../components/RewriteNotice.astro';
import TagArchiveCard from '../../components/TagArchiveCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { chunkEntries, getSeriesEntries, groupArchiveEntriesByYear } from '../../lib/content';
import { isSeriesSlug, seriesList } from '../../lib/series';

const rewriteSeries = new Set([
  'tooling-env',
  'tooling-ops',
  'tooling-hardware',
  'research-nerf',
  'research-cryo',
  'research-essay',
]);

export async function getStaticPaths() {
  return Promise.all(
    seriesList.map(async (meta) => ({
      params: { series: meta.slug },
      props: {
        meta,
        pages: chunkEntries(await getSeriesEntries(meta.slug), 6).map((entries) => groupArchiveEntriesByYear(entries)),
      },
    }))
  );
}

const { meta, pages } = Astro.props;

if (!isSeriesSlug(meta.slug)) {
  throw new Error(`Unknown series route: ${meta.slug}`);
}

const title = meta.label;
const totalPages = Math.max(pages.length, 1);
---

<BaseLayout title={title} description={meta.description}>
  <section class="shell pb-20">
    <div class="section-heading">
      <div>
        <p class="section-kicker">系列归档</p>
        <h1>{title}</h1>
      </div>
    </div>

    <div class="content-shell md:mx-0 md:max-w-[780px] md:px-0">
      <p class="mb-8 text-muted">{meta.description}</p>
      {rewriteSeries.has(meta.slug) && <RewriteNotice scope="series" seriesName={meta.label} />}

      {pages.length > 0 ? (
        <>
          <div data-series-pages>
            {pages.map((pageGroups, index) => (
              <div data-page-index={index + 1} hidden={index !== 0}>
                {pageGroups.map((group) => (
                  <section class="mb-10">
                    <h2 class="mb-4 text-[1.5rem]">{group.year}</h2>
                    <div class="rounded-3xl border border-border px-6 py-2 md:px-8">
                      {group.items.map((entry) => (
                        <TagArchiveCard
                          href={entry.href}
                          title={entry.title}
                          description={entry.description}
                          date={entry.date}
                          tags={entry.tags}
                          type={entry.type}
                          series={entry.series}
                        />
                      ))}
                    </div>
                  </section>
                ))}
              </div>
            ))}
          </div>

          {totalPages > 1 && <Pagination totalPages={totalPages} />}
        </>
      ) : (
        <div class="rounded-3xl border border-border px-6 py-8 text-muted md:px-8">暂无内容。</div>
      )}
    </div>
  </section>

  {totalPages > 1 && (
    <script is:inline define:vars={{ basePath: `/series/${meta.slug}` }}>
      const pageNav = document.querySelector('[data-pagination-nav]');
      const pagePanels = [...document.querySelectorAll('[data-page-index]')];

      if (pageNav && pagePanels.length > 0) {
        const totalPages = Number(pageNav.getAttribute('data-total-pages')) || 1;
        const pageButtons = [...pageNav.querySelectorAll('[data-page-button]')];
        const prevButton = pageNav.querySelector('[data-page-prev]');
        const nextButton = pageNav.querySelector('[data-page-next]');

        const applyButtonState = (page) => {
          pageButtons.forEach((button) => {
            const active = Number(button.getAttribute('data-page-button')) === page;
            button.classList.toggle('border-accent', active);
            button.classList.toggle('bg-accent', active);
            button.classList.toggle('text-white', active);
            button.classList.toggle('text-muted', !active);
          });

          prevButton?.toggleAttribute('disabled', page === 1);
          nextButton?.toggleAttribute('disabled', page === totalPages);
          prevButton?.classList.toggle('opacity-40', page === 1);
          nextButton?.classList.toggle('opacity-40', page === totalPages);
        };

        const setPage = (page) => {
          const nextPage = Math.max(1, Math.min(totalPages, page));

          pagePanels.forEach((panel) => {
            panel.hidden = Number(panel.getAttribute('data-page-index')) !== nextPage;
          });

          applyButtonState(nextPage);
          history.replaceState({}, '', nextPage === 1 ? basePath : `${basePath}#page-${nextPage}`);
        };

        const hashMatch = window.location.hash.match(/page-(\\d+)/);
        setPage(hashMatch ? Number(hashMatch[1]) : 1);

        pageButtons.forEach((button) => {
          button.addEventListener('click', () => {
            setPage(Number(button.getAttribute('data-page-button')));
          });
        });

        prevButton?.addEventListener('click', () => {
          const current = Number(window.location.hash.match(/page-(\\d+)/)?.[1] || 1);
          setPage(current - 1);
        });

        nextButton?.addEventListener('click', () => {
          const current = Number(window.location.hash.match(/page-(\\d+)/)?.[1] || 1);
          setPage(current + 1);
        });

        window.addEventListener('hashchange', () => {
          const match = window.location.hash.match(/page-(\\d+)/);
          setPage(match ? Number(match[1]) : 1);
        });
      }
    </script>
  )}
</BaseLayout>
