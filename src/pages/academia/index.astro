---
import { getCollection } from 'astro:content';
import Academia from '../../layouts/Academia.astro';
import PostCard from '../../components/PostCard.astro';

const teachingEntries = await getCollection('teaching');
const courseEntries = await getCollection('courses');
const publicationEntries = await getCollection('publications');
---

<Academia title="Academia" description="Portfolio landing page for teaching, courses, and publications.">
  <Fragment slot="hero">
    <div class="mb-8 space-y-4">
      <p class="text-sm uppercase tracking-[0.2em] text-accent">Academia</p>
      <h1 class="text-4xl font-semibold tracking-tight">Portfolio scaffold</h1>
      <p class="max-w-2xl text-base leading-8 text-ink-3 dark:text-paper-3">
        Placeholder landing page for teaching history, course records, and publications. Prompt B can replace these
        summaries with curated featured content.
      </p>
    </div>
  </Fragment>

  <div class="academia-grid">
    <PostCard
      href="/academia/teaching/"
      title="Teaching"
      summary={`Teaching archive with ${teachingEntries.length} example entry.`}
      eyebrow="Portfolio"
    />
    <PostCard
      href="/academia/courses/"
      title="Courses"
      summary={`Courses archive with ${courseEntries.length} example entry.`}
      eyebrow="Portfolio"
    />
    <PostCard
      href="/academia/publications/"
      title="Publications"
      summary={`Publication archive with ${publicationEntries.length} example entry.`}
      eyebrow="Portfolio"
    />
  </div>
</Academia>
