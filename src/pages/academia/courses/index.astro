---
import { getCollection } from 'astro:content';
import Academia from '../../../layouts/Academia.astro';
import PostCard from '../../../components/PostCard.astro';

const entries = await getCollection('courses');
---

<Academia title="Courses" description="Courses collection placeholder.">
  <Fragment slot="hero">
    <div class="mb-8 space-y-4">
      <p class="text-sm uppercase tracking-[0.2em] text-accent">Academia / Courses</p>
      <h1 class="text-4xl font-semibold tracking-tight">Courses</h1>
    </div>
  </Fragment>

  <div class="academia-grid">
    {entries.map((entry) => (
      <PostCard
        href={`/academia/courses/${entry.id}/`}
        title={entry.data.title}
        summary={entry.data.summary}
        eyebrow={entry.data.code}
        meta={[entry.data.institution, entry.data.semester].filter(Boolean).join(' · ')}
        tags={entry.data.tags}
      />
    ))}
  </div>
</Academia>
