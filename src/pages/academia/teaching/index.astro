---
import { getCollection } from 'astro:content';
import Academia from '../../../layouts/Academia.astro';
import PostCard from '../../../components/PostCard.astro';

const entries = await getCollection('teaching');
---

<Academia title="Teaching" description="Teaching portfolio entries.">
  <Fragment slot="hero">
    <div class="mb-8 space-y-4">
      <p class="text-sm uppercase tracking-[0.2em] text-accent">Academia / Teaching</p>
      <h1 class="text-4xl font-semibold tracking-tight">Teaching</h1>
    </div>
  </Fragment>

  <div class="academia-grid">
    {entries.map((entry) => (
      <PostCard
        href={`/academia/teaching/${entry.id}/`}
        title={entry.data.title}
        summary={entry.data.summary}
        eyebrow={entry.data.role}
        meta={`${entry.data.course} · ${entry.data.semester}`}
      />
    ))}
  </div>
</Academia>
