---
import { getCollection } from 'astro:content';
import Academia from '../../../layouts/Academia.astro';

const entries = [...(await getCollection('publications'))].sort((a, b) => b.data.year - a.data.year);
const linkOrder = ['pdf', 'code', 'arxiv', 'doi', 'project'] as const;
---

<Academia title="Publications" description="Publications list placeholder.">
  <Fragment slot="hero">
    <div class="mb-8 space-y-4">
      <p class="text-sm uppercase tracking-[0.2em] text-accent">Academia / Publications</p>
      <h1 class="text-4xl font-semibold tracking-tight">Publications</h1>
    </div>
  </Fragment>

  <div class="grid gap-6">
    {entries.map((entry) => (
      <article id={entry.id} class="rounded-[2rem] border border-paper-3 bg-paper p-8 shadow-card dark:border-ink-3 dark:bg-ink-2">
        <p class="text-sm uppercase tracking-[0.16em] text-accent">{entry.data.type}</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight">{entry.data.title}</h2>
        <p class="mt-3 text-sm leading-7 text-ink-3 dark:text-paper-3">{entry.data.authors.join(', ')}</p>
        <p class="mt-2 text-sm text-ink-3 dark:text-paper-3">
          {entry.data.venue} · {entry.data.year}
        </p>
        {entry.data.abstract && <p class="mt-4 max-w-3xl text-sm leading-7 text-ink-3 dark:text-paper-3">{entry.data.abstract}</p>}
        {entry.data.links && (
          <div class="mt-5 flex flex-wrap gap-2">
            {linkOrder
              .filter((key) => entry.data.links?.[key])
              .map((key) => (
                <a
                  class="rounded-full bg-accent-soft px-3 py-1 text-xs font-medium text-accent transition hover:bg-accent hover:text-paper dark:bg-ink dark:text-paper-3 dark:hover:bg-paper dark:hover:text-ink"
                  href={entry.data.links?.[key]}
                >
                  {key}
                </a>
              ))}
          </div>
        )}
      </article>
    ))}
  </div>
</Academia>
