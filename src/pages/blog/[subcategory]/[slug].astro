---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { mdxComponents } from '../../../components/mdx';
import BlogPost from '../../../layouts/BlogPost.astro';
import { formatDate } from '../../../lib/content';
import { blogSubcategoryLabels, blogSubcategoryVariants } from '../../../lib/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: {
      subcategory: post.data.subcategory,
      slug: post.id,
    },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<'blog'> };
const { Content, headings } = await render(post);
const subcategory = post.data.subcategory;
---

<BlogPost
  title={post.data.title}
  description={post.data.summary}
  date={formatDate(post.data.date)}
  tags={post.data.tags}
  subcategoryLabel={blogSubcategoryLabels[subcategory]}
  variant={blogSubcategoryVariants[subcategory]}
  headings={headings}
>
  <Content components={mdxComponents} />
</BlogPost>
