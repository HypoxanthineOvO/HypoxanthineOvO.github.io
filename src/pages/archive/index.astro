---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { formatDate, groupPostsByYear } from '../../lib/content';

const groupedPosts = groupPostsByYear(await getCollection('blog', ({ data }) => !data.draft));
const years = Object.keys(groupedPosts).sort((a, b) => Number(b) - Number(a));
---

<Base title="Archive" description="Blog archive grouped by year.">
  <section class="mx-auto max-w-5xl px-6 py-10">
    <div class="mb-8 space-y-4">
      <p class="text-sm uppercase tracking-[0.2em] text-accent">Archive</p>
      <h1 class="text-4xl font-semibold tracking-tight">By year</h1>
    </div>

    <div class="space-y-10">
      {years.map((year) => (
        <section>
          <h2 class="mb-4 text-2xl font-semibold">{year}</h2>
          <ol class="space-y-3">
            {groupedPosts[year].map((post) => (
              <li class="rounded-2xl border border-paper-3 bg-paper p-4 dark:border-ink-3 dark:bg-ink-2">
                <a class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between" href={`/blog/${post.data.subcategory}/${post.id}/`}>
                  <span class="font-medium">{post.data.title}</span>
                  <span class="text-sm text-ink-3 dark:text-paper-3">{formatDate(post.data.date)}</span>
                </a>
              </li>
            ))}
          </ol>
        </section>
      ))}
    </div>
  </section>
</Base>
