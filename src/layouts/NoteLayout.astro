---
import type { CollectionEntry } from 'astro:content';

import katexCss from 'katex/dist/katex.min.css?raw';

import Prose from '../components/Prose.astro';
import SeriesBadge from '../components/SeriesBadge.astro';
import TOC from '../components/TOC.astro';
import TagList from '../components/TagList.astro';
import { formatDate, type AdjacentArchiveEntry } from '../lib/content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  entry: CollectionEntry<'notes'>;
  Content: any;
  headings: { depth: number; slug: string; text: string }[];
  newer: AdjacentArchiveEntry | null;
  older: AdjacentArchiveEntry | null;
}

const { entry, Content, headings, newer, older } = Astro.props;
const metaDescription = entry.data.description ?? '笔记详情页';
const katexStyles = katexCss;
---

<BaseLayout title={entry.data.title} description={metaDescription}>
  <style slot="head" is:inline set:html={katexStyles} />
  <TOC headings={headings} />

  <article class="shell pb-20">
    <div class="content-shell xl:mr-[18rem]">
      <p class="section-kicker">笔记</p>
      <h1 class="mb-4">{entry.data.title}</h1>
      <div class="mb-6 flex flex-wrap items-center gap-x-4 gap-y-2 font-sans text-sm text-muted">
        <span>发布于 {formatDate(entry.data.date)}</span>
        <SeriesBadge series={entry.data.series} />
        {entry.data.source && <span>来源：{entry.data.source}</span>}
      </div>

      {(entry.data.authors?.length || entry.data.link) && (
        <div class="mb-4 space-y-2 text-sm text-muted">
          {entry.data.authors?.length && <p>作者：{entry.data.authors.join(', ')}</p>}
          {entry.data.link && (
            <p>
              原文链接：{' '}
              <a class="inline-link" href={entry.data.link} target="_blank" rel="noreferrer">
                {entry.data.link}
              </a>
            </p>
          )}
        </div>
      )}

      <div class="mb-10">
        <TagList tags={entry.data.tags ?? []} mode="note" />
      </div>

      <Prose>
        <Content />
      </Prose>

      <nav class="mt-12 grid gap-4 border-t border-border pt-6 font-sans text-sm md:grid-cols-2">
        <div>
          {newer && (
            <>
              <p class="mb-1 text-xs uppercase tracking-[0.16em] text-muted">同系列更新</p>
              <a class="inline-link" href={newer.href}>
                {newer.title}
              </a>
            </>
          )}
        </div>
        <div class="md:text-right">
          {older && (
            <>
              <p class="mb-1 text-xs uppercase tracking-[0.16em] text-muted">同系列更早</p>
              <a class="inline-link" href={older.href}>
                {older.title}
              </a>
            </>
          )}
        </div>
      </nav>
    </div>
  </article>
</BaseLayout>
