---
import Base from './Base.astro';
import '../styles/literary.css';

const { title, description } = Astro.props as { title?: string; description?: string };
---

<Base title={title} description={description} pageClass="literary-shell">
  <section class="literary-page px-6 py-10">
    <slot name="hero" />
    <div class="literary-prose prose prose-slate mx-auto max-w-literary dark:prose-invert">
      <slot />
    </div>
  </section>
</Base>
