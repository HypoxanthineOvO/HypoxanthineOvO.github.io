---
import TOC from '../components/TOC.astro';
import Base from './Base.astro';
import '../styles/technical.css';

const { title, description, headings = [] } = Astro.props as {
  title?: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
};
---

<Base title={title} description={description} pageClass="technical-shell">
  <section class="technical-page mx-auto grid max-w-6xl gap-8 px-6 py-10 lg:grid-cols-[minmax(0,1fr)_260px]">
    <div class="min-w-0">
      <slot name="hero" />
      <div class="technical-prose prose prose-slate max-w-none dark:prose-invert">
        <slot />
      </div>
    </div>
    <aside class="technical-sidebar hidden lg:block">
      <TOC headings={headings} />
    </aside>
  </section>
</Base>
