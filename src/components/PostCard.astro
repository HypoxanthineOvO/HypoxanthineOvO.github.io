---
import type { CollectionEntry } from 'astro:content';

import { formatDate } from '../lib/content';
import TagList from './TagList.astro';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
---

<article class="border-b border-border py-6 last:border-b-0">
  <p class="mb-2 font-sans text-xs uppercase tracking-[0.16em] text-muted">{formatDate(post.data.date)}</p>
  <h3 class="mb-2 text-[1.25rem]">
    <a class="transition-colors duration-150 hover:text-accent" href={`/posts/${post.id}`}>
      {post.data.title}
    </a>
  </h3>
  {post.data.description && <p class="mb-3 text-[0.98rem] text-muted">{post.data.description}</p>}
  <TagList tags={post.data.tags} mode="post" />
</article>
