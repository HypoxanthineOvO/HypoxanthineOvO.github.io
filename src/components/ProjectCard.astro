---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;

const badgeClassMap = {
  Active: 'status-badge--active',
  WIP: 'status-badge--wip',
  Archived: 'status-badge--archived',
  Idea: 'status-badge--idea',
} as const;
---

<article class="surface-card p-6">
  <div class="mb-4 flex flex-wrap items-center gap-3">
    <h3 class="text-[1.2rem]">{project.data.name}</h3>
    <span class:list={['status-badge', badgeClassMap[project.data.status]]}>
      {project.data.status}
    </span>
  </div>

  <p class="mb-4 text-muted">{project.data.description}</p>

  <div class="mb-4 flex flex-wrap gap-2">
    {project.data.tech.map((item) => (
      <span class="tag-pill">{item}</span>
    ))}
  </div>

  <div class="flex flex-wrap gap-3 font-sans text-sm">
    {project.data.repo && (
      <a class="inline-link" href={project.data.repo} target="_blank" rel="noreferrer">
        Repository
      </a>
    )}
    {project.data.link && (
      <a class="inline-link" href={project.data.link} target="_blank" rel="noreferrer">
        Project Link
      </a>
    )}
  </div>
</article>
