---
import { Rss } from '@lucide/astro';

import { siteConfig } from '../lib/site';

const githubMarkPath =
  'M12 .297a12 12 0 0 0-3.794 23.385c.6.113.82-.258.82-.577v-2.234c-3.338.726-4.042-1.416-4.042-1.416a3.18 3.18 0 0 0-1.335-1.755c-1.09-.745.083-.729.083-.729a2.52 2.52 0 0 1 1.84 1.237 2.555 2.555 0 0 0 3.49.997 2.554 2.554 0 0 1 .762-1.6C7.16 17.31 4.36 16.27 4.36 11.67a4.573 4.573 0 0 1 1.218-3.172 4.25 4.25 0 0 1 .116-3.127s.996-.318 3.26 1.214a11.274 11.274 0 0 1 5.932 0c2.264-1.532 3.26-1.214 3.26-1.214a4.25 4.25 0 0 1 .116 3.127 4.573 4.573 0 0 1 1.218 3.172c0 4.61-2.804 5.636-5.475 5.932a2.868 2.868 0 0 1 .814 2.224v3.293c0 .322.216.694.825.576A12.003 12.003 0 0 0 12 .297Z';
---

<footer class="border-t border-border bg-[var(--bg-subtle)] py-10">
  <div class="shell flex flex-col gap-3 text-sm text-muted md:flex-row md:items-center md:justify-between">
    <div class="space-y-1">
      <p>© 2026 Yunxiang He</p>
      <p>基于 Astro 构建</p>
    </div>

    <div class="flex flex-wrap items-center gap-4">
      <a class="social-link text-muted hover:text-accent" href={siteConfig.github} target="_blank" rel="noreferrer" aria-label="GitHub">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d={githubMarkPath}></path>
        </svg>
        <span>GitHub</span>
      </a>
      <a class="social-link text-muted hover:text-accent" href="/rss.xml" aria-label="RSS">
        <Rss size={16} stroke-width={1.8} aria-hidden="true" />
        <span>RSS</span>
      </a>
      <a class="social-link text-muted hover:text-accent" href={`mailto:${siteConfig.email}`}>
        <span>Email</span>
      </a>
    </div>
  </div>
</footer>
