---
import { siteConfig } from '../lib/site';

const year = new Date().getUTCFullYear();
---

<footer class="border-t border-border bg-[var(--bg-subtle)] py-10">
  <div class="shell flex flex-col gap-2 text-sm text-muted md:flex-row md:items-center md:justify-between">
    <p>© {year} Hypoxanthine</p>
    <p class="flex flex-wrap items-center gap-3">
      <a class="transition-colors duration-150 hover:text-accent" href={siteConfig.github} target="_blank" rel="noreferrer">
        GitHub
      </a>
      <span>·</span>
      <a class="transition-colors duration-150 hover:text-accent" href={`mailto:${siteConfig.email}`}>
        Email
      </a>
    </p>
  </div>
</footer>
