---
interface Props {
  totalPages: number;
}

const { totalPages } = Astro.props;
---

{
  totalPages > 1 && (
    <nav class="mt-8 flex flex-wrap items-center gap-2 font-sans text-sm" data-pagination-nav data-total-pages={totalPages} aria-label="Pagination">
      <button
        type="button"
        class="rounded-full border border-border px-3 py-1.5 text-muted transition-colors duration-150 hover:border-accent hover:text-accent"
        data-page-prev
      >
        Prev
      </button>
      {Array.from({ length: totalPages }, (_, index) => index + 1).map((page) => (
        <button
          type="button"
          class="rounded-full border border-border px-3 py-1.5 text-muted transition-colors duration-150 hover:border-accent hover:text-accent"
          data-page-button={page}
        >
          {page}
        </button>
      ))}
      <button
        type="button"
        class="rounded-full border border-border px-3 py-1.5 text-muted transition-colors duration-150 hover:border-accent hover:text-accent"
        data-page-next
      >
        Next
      </button>
    </nav>
  )
}
