---
type Props = {
  currentPage: number;
  totalPages: number;
  previousHref?: string;
  nextHref?: string;
};

const { currentPage, totalPages, previousHref, nextHref } = Astro.props as Props;
---

<nav class="flex items-center justify-between rounded-3xl border border-paper-3 bg-paper-2 px-5 py-4 text-sm dark:border-ink-3 dark:bg-ink-2">
  <a class:list={['transition hover:text-accent', !previousHref && 'pointer-events-none opacity-40']} href={previousHref ?? '#'}>
    Previous
  </a>
  <span class="text-ink-3 dark:text-paper-3">
    Page {currentPage} / {totalPages}
  </span>
  <a class:list={['transition hover:text-accent', !nextHref && 'pointer-events-none opacity-40']} href={nextHref ?? '#'}>
    Next
  </a>
</nav>
