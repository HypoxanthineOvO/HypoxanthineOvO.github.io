---
import Nav from './Nav.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-border bg-[var(--surface)] backdrop-blur">
  <div class="shell flex min-h-[4.5rem] flex-wrap items-center justify-between gap-3 py-3">
    <a href="/" class="font-sans text-[1rem] font-semibold tracking-tight text-text transition-colors duration-150 hover:text-accent">
      Hypoxanthine
    </a>

    <div class="flex items-center gap-4">
      <Nav />
      <ThemeToggle />
    </div>
  </div>
</header>
