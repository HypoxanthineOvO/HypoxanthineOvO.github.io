---
import type { CollectionEntry } from 'astro:content';

interface Props {
  publication: CollectionEntry<'publications'>;
}

const { publication } = Astro.props;
const isAcademic = publication.data.kind !== 'literary';
const detailHref = `/publications/${publication.id}`;

const links: { href: string; label: string }[] = [];

if (publication.data.pdf) {
  links.push({ href: publication.data.pdf, label: 'PDF' });
}

if (publication.data.code) {
  links.push({ href: publication.data.code, label: 'Code' });
}

if (publication.data.project_page) {
  links.push({ href: publication.data.project_page, label: 'Site' });
}
---

<article class="surface-card publication-card p-6">
  <div class="publication-card__inner">
    <div class="publication-card__meta">
      <h3 class="mb-3 text-[1.2rem]">
        <a class="transition-colors duration-150 hover:text-accent" href={detailHref}>
          {publication.data.title}
        </a>
      </h3>
      {publication.data.authors?.length && (
        <p class="mb-2 text-sm leading-relaxed text-muted">
          {
            publication.data.authors.map((author, index) => (
              <>
                {index > 0 && ', '}
                {author === 'Yunxiang He' ? (
                  <strong class="font-semibold text-text underline decoration-accent/60 underline-offset-4">{author}</strong>
                ) : (
                  author
                )}
              </>
            ))
          }
        </p>
      )}
      <p class="font-sans text-sm text-muted">
        {isAcademic ? (
          <>
            {publication.data.venue ?? '期刊 / 会议待补'} · {publication.data.year}
          </>
        ) : publication.data.venue ? (
          <>
            {publication.data.year} · {publication.data.venue}
          </>
        ) : (
          <>{publication.data.year}</>
        )}
      </p>
    </div>

    {links.length > 0 && (
      <div class="publication-card__actions font-sans text-sm">
        {links.map((link) => (
          <a class="link-btn" href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noreferrer' : undefined}>
            [{link.label}]
          </a>
        ))}
        <a class="link-btn" href={detailHref}>
          [详情]
        </a>
      </div>
    )}
    {links.length === 0 && (
      <div class="publication-card__actions font-sans text-sm">
        <a class="link-btn" href={detailHref}>
          [详情]
        </a>
      </div>
    )}
  </div>
</article>
