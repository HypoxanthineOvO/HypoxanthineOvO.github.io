---
import { formatTagLabel, toTagParam } from '../lib/content';

interface Props {
  tags: string[];
  mode?: 'post' | 'note';
  linkToTags?: boolean;
}

const { tags, mode = 'post', linkToTags = true } = Astro.props;
---

{
  tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) =>
        linkToTags ? (
          <a class="tag-pill transition-colors duration-150 hover:border-accent hover:text-accent" href={`/tags/${toTagParam(tag)}`}>
            {formatTagLabel(tag, mode)}
          </a>
        ) : (
          <span class="tag-pill">{formatTagLabel(tag, mode)}</span>
        )
      )}
    </div>
  )
}
