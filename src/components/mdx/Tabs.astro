---
const { items = [] } = Astro.props as { items?: string[] };
---

<div class="my-6 rounded-3xl border border-paper-3 bg-paper-2 p-4 dark:border-ink-3 dark:bg-ink-2">
  <div class="flex flex-wrap gap-2">
    {items.map((item) => (
      <span class="rounded-full border border-accent/20 px-3 py-1 text-xs font-medium text-accent dark:border-paper/20 dark:text-paper-3">
        {item}
      </span>
    ))}
  </div>
  <p class="mt-3 text-sm text-ink-3 dark:text-paper-3">
    Placeholder tabs component for future Hexo tag migration.
  </p>
</div>
