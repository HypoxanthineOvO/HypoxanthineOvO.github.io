---
const { title = 'Callout', tone = 'info' } = Astro.props as { title?: string; tone?: 'info' | 'warning' | 'success' };

const toneClasses = {
  info: 'border-accent/30 bg-accent-soft/70 text-ink dark:border-accent/50 dark:bg-ink-2 dark:text-paper',
  warning: 'border-amber-400/40 bg-amber-50 text-amber-950 dark:border-amber-300/40 dark:bg-amber-950/20 dark:text-amber-100',
  success: 'border-emerald-400/40 bg-emerald-50 text-emerald-950 dark:border-emerald-300/40 dark:bg-emerald-950/20 dark:text-emerald-100',
}[tone];
---

<aside class:list={['my-6 rounded-3xl border px-5 py-4', toneClasses]}>
  <p class="mb-2 text-sm font-semibold uppercase tracking-[0.16em]">{title}</p>
  <div class="text-sm leading-7">
    <slot />
  </div>
</aside>
